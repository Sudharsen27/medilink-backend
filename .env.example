# =============================================================================
# LOCAL development (PostgreSQL on your machine / pgAdmin)
# =============================================================================
PORT=5000
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_local_db_password
DB_NAME=medilink

# =============================================================================
# PRODUCTION (Supabase) — set these on your hosting platform (Render/Railway/etc.)
# Do NOT commit real secrets. Supabase database name is usually "postgres".
# =============================================================================
# DB_SSL=true
# DB_HOST=aws-1-ap-northeast-1.pooler.supabase.com
# DB_PORT=5432
# DB_USER=postgres.YOUR_PROJECT_REF
# DB_PASSWORD=your_supabase_db_password
# DB_NAME=postgres

JWT_SECRET=change_this_to_a_long_random_secret

# Comma-separated extra frontend URLs allowed by CORS (optional)
# CORS_ORIGINS=https://your-custom-domain.com,https://another-frontend.vercel.app

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Gmail (app password)
EMAIL_USER=
EMAIL_PASS=
CLIENT_EMAIL=

# Cloudinary
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Calendar + Meet (optional — video appointments)
# 1. Create a Google Cloud project and enable Google Calendar API
# 2. Create a service account and download the JSON key
# 3. Share your Google Calendar with the service account email (Make changes to events)
# 4. Set GOOGLE_CALENDAR_ID to that calendar's ID (often your Gmail address)
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_CALENDAR_ID=your-calendar@gmail.com
# GOOGLE_CALENDAR_TIMEZONE=Asia/Kolkata
# GOOGLE_CALENDAR_IMPERSONATE_EMAIL=   # optional: Workspace domain-wide delegation
# GOOGLE_CALENDAR_CREATE_ON_BOOK=true  # create Meet link immediately on booking (video only)

# For Google Meet links on personal Gmail (run: npm run google:auth)
# OAuth client must be "Web application" with redirect URI:
#   http://localhost:8765/oauth2callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALENDAR_REFRESH_TOKEN=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8765/oauth2callback
